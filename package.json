{
  "name": "NearsecTogether",
  "version": "2.0.6",
  "author": "Fame <support@cutefame.net>",
  "description": "Browser-based game streaming host",
  "main": "electron-main.js",
  "scripts": {
    "start": "node src/scripts/server.js",
    "test": "node bin/verify.js",
    "electron": "electron .",
    "dev": "electron . --dev",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "dist": "electron-builder --publish always",
    "dist:win": "electron-builder --win --publish always",
    "dist:mac": "electron-builder --mac --publish always",
    "dist:linux": "electron-builder --linux --publish always"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.18.0",
    "kill-port": "^2.0.1",
    "open": "^10.1.0",
    "pusher-js": "^8.5.0",
    "which": "^4.0.0",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "wrangler": "^4.90.0"
  },
  "build": {
    "appId": "com.nearsectogether.app",
    "productName": "NearsecTogether",
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "!/.env",
      "**/*",
      "!website",
      "!src/docs",
      "!**/*.md",
      "!.github",
      "!kbm_presets",
      "!.flatpak-builder",
      "!**/build/Release/.deps",
      "!**/build/Release/obj.target",
      "!**/build/Release/*.a",
      "!**/build/*.mk",
      "!**/build/Makefile",
      "!**/build/*.gypi"
    ],
    "asarUnpack": [
      "src/sidecar/**/*",
      "assets/**/*",
      "bin/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/NearsecTogether.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/NearsecTogether.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "icon": "assets/NearsecTogether.png",
      "category": "Game"
    }
  }
}
