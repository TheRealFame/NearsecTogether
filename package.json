{
  "name": "NearsecTogether",
  "version": "1.0.0",
  "author": "Fame <support@cutefame.net>",
  "description": "Browser-based game streaming host",
  "main": "electron-main.js",
  "scripts": {
    "start": "node src/scripts/server.js",
    "electron": "electron .",
    "dev": "electron . --dev",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"

  },
  "dependencies": {
    "express": "^4.18.0",
    "pusher-js": "^8.5.0",
    "ws": "^8.0.0",
    "open": "latest",
    "play-sound": "latest",
    "kill-port": "latest",
    "which": "latest"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "wrangler": "^4.90.0"
  },
  "build": {
    "appId": "com.nearsectogether.app",
    "productName": "NearsecTogether",
    "directories": {
      "output": "dist"
    },
    "files": [
      "!/.env",
      "**/*",
      "!website",
      "!src/docs",
      "!**/*.md",
      "!.github",
      "!kbm_presets"
    ],
    "asarUnpack": [
      "src/sidecar/**/*",
      "bin/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/NearsecTogether.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/NearsecTogether.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/NearsecTogether.png",
      "category": "Network"
    }
  }
}
