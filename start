#!/usr/bin/env bash
# Nearsec Together Launcher
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"

echo ""
echo "  ┌─────────────────────────────────────┐"
echo "  │      Nearsec Together Launcher      │"
echo "  └─────────────────────────────────────┘"
echo ""

# 1. OS Detection & Setup Routing
OS="$(uname -s)"
case "${OS}" in
    Linux*)     
        setup_script="./bin/linux_setup.sh"
        if ! lsmod | grep -q uinput; then
          sudo modprobe uinput 2>/dev/null && echo "  ✓ uinput loaded"
        fi
        if [ -e /dev/uinput ] && [ ! -w /dev/uinput ]; then
          sudo chmod 666 /dev/uinput 2>/dev/null
        fi
        if [ -x "./fix_steam_input.sh" ]; then
          ./fix_steam_input.sh
        fi
        ;;
    Darwin*)    
        setup_script="./bin/macos_setup.sh"
        ;;
    CYGWIN*|MINGW32*|MSYS*|MINGW*) 
        setup_script="./bin/windows_setup.ps1"
        ;;
    *)          
        setup_script=""
        ;;
esac

# 2. .env Generation
if [ ! -f .env ]; then
  echo "  ! Generating .env template..."
# NearsecTogether Config
CF_TOKEN=
CUSTOM_URL=
ZROK_RESERVED_NAME=
USE_VPS=false
VPS_HOST=
IS_VPS=false
EOF
  echo "  ✓ .env generated. Edit it to add your tunnel tokens."
fi

# 3. Environment Checks
if ! command -v node &>/dev/null; then
  echo "  ✗ Node.js not found. Install: https://nodejs.org"; exit 1
fi

if [ ! -d node_modules ]; then
  echo "  ! Installing npm packages..."
  npm install --silent && echo "  ✓ Packages installed"
fi

# 4. Steam Input Bypass
# SDL_GAMECONTROLLER_IGNORE_DEVICES tells SDL to skip our emulated pads by VID:PID
export SDL_GAMECONTROLLER_IGNORE_DEVICES="0x045e/0x028e,0x054c/0x09cc,0x054c/0x0ce6"

# 5. Launch
fuser -k 3000/tcp 2>/dev/null || true

if [ -f node_modules/.bin/electron ]; then
  echo "  ▶ Launching NearsecTogether host app..."
  exec node_modules/.bin/electron . "$@"
else
  echo "  ▶ Launching NearsecTogether headless..."
  exec node src/server.js "$@"
fi
